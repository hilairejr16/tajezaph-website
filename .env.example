# ============================================================
# TAJEZAPH Home Improvement — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Supabase (https://supabase.com — free tier)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend email service (https://resend.com — free tier 3k/month)
RESEND_API_KEY=re_your_api_key
CONTACT_EMAIL=emmanuellouis79@yahoo.com
FROM_EMAIL=noreply@tajezaphservices.com

# Google reCAPTCHA v3 (https://www.google.com/recaptcha)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# Cloudinary (https://cloudinary.com — free tier)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Analytics (https://analytics.google.com)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Admin authentication secret (generate a strong random string)
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars
NEXTAUTH_URL=https://tajezaphservices.com

# Admin credentials (hashed — use bcrypt)
ADMIN_EMAIL=emmanuellouis79@yahoo.com
ADMIN_PASSWORD_HASH=your-bcrypt-hash

# WhatsApp Business number (with country code, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=12677883933

# Calendly embed URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/tajezaph-services

# Business info
NEXT_PUBLIC_BUSINESS_PHONE=+1 (267) 788-3933
NEXT_PUBLIC_BUSINESS_EMAIL=emmanuellouis79@yahoo.com
NEXT_PUBLIC_BUSINESS_ADDRESS=Philadelphia, PA
